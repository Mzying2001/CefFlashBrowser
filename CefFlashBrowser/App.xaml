<Application x:Class="CefFlashBrowser.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CefFlashBrowser"
             xmlns:c="clr-namespace:CefFlashBrowser.Views.Custom"
             xmlns:vm="clr-namespace:CefFlashBrowser.ViewModels"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
             xmlns:infraWpf="clr-namespace:CefFlashBrowser.Infrastructure.Wpf">
    <Application.Resources>
        <ResourceDictionary>


            <ResourceDictionary.MergedDictionaries>
                <!--Language-->
                <infraWpf:NamedResourceDictionary Name="Language" Source="Assets/Language/zh-CN.xaml"/>

                <!--HandyControl-->
                <infraWpf:NamedResourceDictionary Name="Skin" Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml"/>
                <infraWpf:NamedResourceDictionary Name="Theme" Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>

                <!--Converters-->
                <infraWpf:NamedResourceDictionary Name="Converters" Source="Views/Converters/Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>


            <!--ViewModelLocator-->
            <vm:ViewModelLocator x:Key="Locator"/>


            <!--Application Info-->
            <infraWpf:AppInfo x:Key="AppInfo"/>


            <!--Custom window style, WindowManager will set this for all windows-->
            <Style x:Key="CustomWindowStyle" TargetType="Window">
                <Setter Property="Background" Value="{DynamicResource RegionBrush}"/>
            </Style>


            <!--Change icon colors according to the theme-->
            <Style TargetType="{x:Type svgc:SvgIcon}">
                <Setter Property="Fill" Value="{DynamicResource PrimaryTextBrush}"/>
            </Style>


        </ResourceDictionary>
    </Application.Resources>
</Application>
